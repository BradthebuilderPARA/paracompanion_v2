{
  "name": "paracompanion",
  "private": true,
  "scripts": {
    "build": "turbo run build --filter=!mobile",
    "build:web": "turbo run build --filter=web",
    "build:admin": "turbo run build --filter=admin",
    "vercel-build": "turbo run build --filter=web",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "playwright": "^1.58.2",
    "prettier": "^3.7.4",
    "turbo": "^2.8.20",
    "next": "14.2.3",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": "24.x"
  },
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0"
    },
    "patchedDependencies": {
      "zustand@4.5.7": "patches/zustand@4.5.7.patch"
    }
  }
}
