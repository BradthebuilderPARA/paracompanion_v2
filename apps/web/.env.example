# ──────────────────────────────────────────────────────────────────────────────
# apps/web — Environment Variables
# Copy this file to .env.local and fill in values before running the app.
#   cp apps/web/.env.example apps/web/.env.local
# .env.local is never committed to git (see .gitignore).
# ──────────────────────────────────────────────────────────────────────────────

# Supabase — your project URL (found in Supabase Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase — public anon key (safe to expose in the browser; security is enforced by Row Level Security)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Supabase — service role key (NEVER expose in the browser; server-side only)
# Required for server actions that need elevated database access (e.g. placement sign-offs).
# If not set, falls back to the anon key (reduced permissions).
# Get it from: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Base URL of the web app — used by the Stripe checkout route to build redirect URLs.
# Use http://localhost:3000 for local development; set to your Vercel URL for preview/production.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe — secret API key (NEVER share or commit a live key).
# Get your TEST key from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
